{
  "name": "@futo-org/restic-wrapper",
  "version": "1.1.0",
  "description": "TypeScript wrapper library for the restic backup tool",
  "keywords": [
    "restic",
    "backup",
    "typescript",
    "wrapper"
  ],
  "homepage": "https://github.com/immich-app/restic-wrapper-ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "pnpm run lint -- --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:ui": "vitest --ui"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/immich-app/restic-wrapper-ts.git"
  },
  "bugs": {
    "url": "https://github.com/immich-app/restic-wrapper-ts/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@size-limit/preset-small-lib": "^8.2.4",
    "@types/node": "^22.18.1",
    "@vitest/coverage-istanbul": "3.2.4",
    "@vitest/ui": "3.2.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "node-stream-zip": "^1.15.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tar": "^7.5.4",
    "tsdown": "^0.15.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.47.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "zod": "^4.1.12"
  }
}
